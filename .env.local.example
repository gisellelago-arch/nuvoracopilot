# Supabase — encontre em Project Settings > API no painel do Supabase
# ATENÇÃO: a URL PRECISA começar com "https://" (não é só o domínio).
# A chave pode ser tanto o formato antigo (começa com "eyJ...") quanto o
# novo formato "Publishable key" (começa com "sb_publishable_...") — os
# dois funcionam aqui sem nenhuma mudança de código.
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-ou-publishable-key

# IA — pertence ao NuvoraCopilot, não ao médico. Sem prefixo NEXT_PUBLIC_:
# só o servidor lê esta variável (ver lib/ai/providers/openai.provider.ts).
# Necessária a partir de agora — sem ela, a transcrição e o SOAP falham.
OPENAI_API_KEY=sk-...

# Opcional — só defina se precisar trocar o modelo padrão (ex: se um
# modelo for descontinuado pela OpenAI). Veja os valores padrão em
# lib/ai/providers/openai.provider.ts.
# OPENAI_MODELO_TRANSCRICAO=whisper-1
# OPENAI_MODELO_CHAT=gpt-5-mini
